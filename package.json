{
  "name": "@giolabsuy/ai-code-reviewer",
  "version": "0.1.0-beta.14",
  "description": "AI-powered code reviewer for GitHub PRs — supports OpenAI, Anthropic, Gemini and Ollama",
  "type": "module",
  "bin": {
    "ai-code-reviewer": "dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "templates",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "prepublishOnly": "npm run build",
    "start": "node dist/cli.js",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "code-review",
    "ai",
    "openai",
    "anthropic",
    "gemini",
    "ollama",
    "multi-provider",
    "github-actions",
    "pull-request",
    "cli",
    "static-analysis"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/giolabs/ai-code-reviewer"
  },
  "author": "Giolabs",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@actions/core": "^1.11.0",
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.21.0",
    "@octokit/graphql": "^9.0.3",
    "@octokit/rest": "^21.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "js-yaml": "^4.1.0",
    "madge": "^8.0.0",
    "openai": "^4.67.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/madge": "^5.0.3",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.6",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.6"
  }
}
